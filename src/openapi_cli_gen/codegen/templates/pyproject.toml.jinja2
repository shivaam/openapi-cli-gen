[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ name }}"
version = "0.1.0"
description = "CLI for {{ name }} API"
requires-python = ">=3.10"
dependencies = [
    "openapi-cli-gen>={{ openapi_cli_gen_version }}",
]

[project.scripts]
{{ name }} = "{{ name }}.cli:main"
