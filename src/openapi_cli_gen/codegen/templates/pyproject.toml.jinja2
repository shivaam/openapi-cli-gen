[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ name }}"
version = "0.1.0"
description = "CLI for {{ name }} API, generated by openapi-cli-gen"
requires-python = ">=3.10"
dependencies = [
    "openapi-cli-gen>={{ openapi_cli_gen_version }}",
]

[project.scripts]
{{ name }} = "{{ module_name }}.cli:main"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]
